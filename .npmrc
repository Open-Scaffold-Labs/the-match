# eslint-plugin-react (jsx-no-undef gate) declares peer eslint <=9.7 while we run
# eslint 10 — no compatible release exists (checked 2026-07-07, latest 7.37.5).
# The rule itself works on eslint 10 flat config (regression-proven in repo).
# This flag must be COMMITTED so Vercel's `npm install --include=dev` resolves
# identically to local installs — a shell-only flag would pass locally and fail CI.
legacy-peer-deps=true
