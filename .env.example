# Copy to .env and fill in values

# Supabase — session pooler URL (aws-east.pooler.supabase.com:5432)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Client (dev)
CLIENT_ORIGIN=http://localhost:5173

# Anthropic (for Eagle Eye + AI Caddie)
ANTHROPIC_API_KEY=sk-ant-...

# Vercel (set in dashboard, not here)
# APP_BASE_URL=https://the-match.vercel.app

# Native iOS/Android (Capacitor) build ONLY. The bundled app's webview origin is
# capacitor://localhost, so the client must call the deployed API by absolute URL.
# Set this when building the native bundle (leave UNSET for web/PWA builds):
#   VITE_API_ORIGIN=https://<prod-domain> npm run build --workspace client
# then: npx cap sync ios. Confirm the real production API domain before submitting.
# VITE_API_ORIGIN=https://the-match.vercel.app
