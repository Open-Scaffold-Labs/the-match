{
  "appId": "com.openscaffoldlabs.thematch",
  "appName": "The Match",
  "webDir": "dist",
  "ios": {
    "contentInset": "never",
    "backgroundColor": "#070C09"
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "CapacitorUpdater": {
      "autoUpdate": true,
      "resetWhenUpdate": true,
      "updateUrl": "https://the-match-roan.vercel.app/api/v1/ota/updates",
      "statsUrl": "https://the-match-roan.vercel.app/api/v1/ota/stats"
    },
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#070C09",
      "showSpinner": true,
      "iosSpinnerStyle": "large",
      "spinnerColor": "#C9A040"
    },
    "Keyboard": {
      "resize": "native"
    }
  }
}
